FRED_API_KEY=your_key_here

# Schwab OAuth (see README for setup)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
# Encryption key for Schwab tokens at rest (required in production)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SCHWAB_ENCRYPTION_KEY=

# Alpha Vantage — free key for earnings calendar (25 req/day)
# Get one at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Authentication (opt-in — app works without these, set all 3 to enable)
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Comma-separated GitHub usernames (empty = allow all authenticated users)
ALLOWED_USERS=

# Production deployment (used by docker-compose.prod.yml)
DOMAIN=regression.yourdomain.com

# Optional: basic auth (leave empty for open access)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
