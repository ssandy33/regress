FRED_API_KEY=your_key_here

# Schwab OAuth (see README for setup)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# Alpha Vantage — free key for earnings calendar (25 req/day)
# Get one at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Production deployment (used by docker-compose.prod.yml)
DOMAIN=regression.yourdomain.com

# Optional: basic auth (leave empty for open access)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
